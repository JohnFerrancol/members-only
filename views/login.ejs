<h1>Login Page</h1>
<form method="POST" action="/login">
  Enter Username:
  <br /><input type="text" name="username" required /> <br />Enter Password:
  <br /><input type="password" name="password" required />
  <br />
  <br />
  <input type="submit" value="Submit" />

  <% messages.forEach(msg => { %>
  <p class="error"><%= msg %></p>
  <% }) %>
</form>
