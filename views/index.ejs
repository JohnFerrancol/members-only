<div>
  <h1>Home Page</h1>
  <% posts.forEach(post => { %>
  <div class="post-container">
    <h2>
      <%= (locals.user) ? post.username : '*'.repeat(post.username.length) %>
    </h2>
    <h2><%= post.created_at %></h2>
    <h2><%= post.title %></h2>
    <h2><%= post.content %></h2>
  </div>
  <% }) %>
</div>
