<nav class="navigation-container">
  <i class="fa-solid fa-people-group fa-xl app-icon"></i>

  <div class="navigation-links-container">
    <% links.forEach(link => { %> <% if (link.isText) { %>
    <div class="username-wrapper">
      <i class="fa-solid fa-user-shield"></i>
      <span class="username-display"><%= link.text %></span>
    </div>
    <% } else { %>
    <a href="<%= link.href %>" class="navigation-links"><%= link.text %></a>
    <% } %> <% }) %>
  </div>
</nav>
