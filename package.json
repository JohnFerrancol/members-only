{
  "type": "module",
  "dependencies": {
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-ejs": "^1.0.3"
  },
  "scripts": {
    "lint": "eslint .",
    "format:js": "prettier --write 'routes/**/*.js' 'controllers/**/*.js' 'middleware/**/*.js'",
    "format:ejs": "prettier --plugin=prettier-plugin-ejs --write 'views/**/*.ejs'",
    "format": "npm run format:js && npm run format:ejs",
    "start": "node --watch app.js"
  }
}
